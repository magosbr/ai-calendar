{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": ".",
    "baseUrl": "./",
    "paths": {
      "@tools/*": ["./src/ai/tools/*"],
      "@models/*": ["./src/core/models/*"],
      "@implementations/*": ["./src/core/implementations/*"],
      "@repositories/*": ["./src/core/repositories/*"],
      "@agents/*": ["./src/ai/agents/*"]
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
